{
  email admin@trumpus.tech
}

(block_secrets) {
  @forbidden path /.env* /.git/* /.vscode/* /docker-compose* /Caddyfile
  respond @forbidden 403
}

(common_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}

trumpus.tech {
  import block_secrets
  import common_headers

  route {
    handle /api/v1/ws* {
      reverse_proxy trumpus_api:8000
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-For {remote}
    }
    handle /api/* {
      reverse_proxy trumpus_api:8000
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-For {remote}
    }

    handle {
      reverse_proxy trumpus_client_web:80
    }
  }
}

admin.trumpus.tech {
  import block_secrets
  import common_headers

  route {
    handle /api/v1/ws* {
      reverse_proxy trumpus_api:8000
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-For {remote}
    }
    handle /api/* {
      reverse_proxy trumpus_api:8000
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-For {remote}
    }

    handle {
      reverse_proxy trumpus_admin_web:80
    }
  }
}

api.trumpus.tech {
  import block_secrets
  import common_headers

  reverse_proxy trumpus_api:8000
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Forwarded-For {remote}
}
