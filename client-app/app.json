{
  "expo": {
    "name": "Trumpus",
    "slug": "trumpus",
    "scheme": "trumpus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trumpus",
      "associatedDomains": [
        "applinks:trumpus.tech"
      ]
    },
    "android": {
      "package": "com.trumpus",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "trumpus.tech",
              "pathPrefix": "/reset"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "autoVerify": true
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "trumpus"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.googleusercontent.apps.813736117005-6k1n7ku4ono5rt32vsu2deg6cffe83uh"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "apiBaseUrl": "https://app.privetsuper.ru:18000/api/v1",
      "googleAndroidClientId": "813736117005-6k1n7ku4ono5rt32vsu2deg6cffe83uh.apps.googleusercontent.com",
      "googleWebClientId": "813736117005-jm3t8ousstjbra6tcbe2hpi6khoeqhor.apps.googleusercontent.com",
      "eas": {
        "projectId": "58c15bb6-30f2-47a2-b779-15316d36ff60"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store"
    ]
  }
}
